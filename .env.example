# ── Base de données PostgreSQL ───────────────────
# Local (développement) — pas de sslmode :
DATABASE_URL="postgresql://postgres:TONMOTDEPASSE@localhost:5432/mam_buudu"
# Cloud Render (production) — avec sslmode=require :
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/mam_buudu?sslmode=require"

# ── JWT ──────────────────────────────────────────
JWT_SECRET="remplace_par_une_chaine_aleatoire_de_64_chars"
JWT_EXPIRES_IN="30d"

# ── Serveur ───────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── URL publique de l'API (pour les URLs de photos) ──
API_BASE_URL="https://mam-buudu-api.onrender.com"

# ── CORS : origines autorisées (séparées par des virgules) ──
# En prod : laisser vide pour tout autoriser, ou mettre des domaines précis
CORS_ORIGIN=""
